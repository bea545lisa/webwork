<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # www auf Nicht-www umleiten (301) - vermeidet Duplicate-Content zwischen
    # www.webwork-oberland.de und webwork-oberland.de, passend zu Canonical-Tags/Sitemap.
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

    # Alle Aufrufe von index.php (alte Joomla-Website, mit oder ohne Parameter):
    # 410 Gone statt 200, damit Google diese längst gelöschten Seiten aus dem
    # Index nimmt. Prüft %{THE_REQUEST} (die tatsächliche Browser-Anfrage),
    # NICHT den aktuellen Rewrite-Pfad - sonst greift die Regel auch bei der
    # internen Weiterleitung JEDER normalen Seite auf index.php (siehe unten)
    # und blockiert damit versehentlich die ganze Website.
    RewriteCond %{THE_REQUEST} \s/index\.php[?\s]
    RewriteRule ^ - [G,L]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
